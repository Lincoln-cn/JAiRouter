# =============================================================================
# JAiRouter - AI Model Service Routing Gateway
# Git Ignore Configuration
# =============================================================================

# -----------------------------------------------------------------------------
# Build Outputs
# -----------------------------------------------------------------------------
target/
!**/src/main/**/target/
!**/src/test/**/target/

# Maven Wrapper
!.mvn/wrapper/maven-wrapper.jar

# -----------------------------------------------------------------------------
# IDE & Editor
# -----------------------------------------------------------------------------
# IntelliJ IDEA
.idea/
*.iws
*.iml
*.ipr
.idea/modules.xml
.idea/jarRepositories.xml
.idea/compiler.xml
.idea/libraries/

# Eclipse
.apt_generated
.classpath
.factorypath
.project
.settings
.springBeans
.sts4-cache

# VS Code
.vscode/

# NetBeans
/nbproject/private/
/nbbuild/
/dist/
/nbdist/
/.nb-gradle/
build/
!**/src/main/**/build/
!**/src/test/**/build/

# Kiro (AI IDE)
.kiro/

# -----------------------------------------------------------------------------
# Frontend (Vue 3)
# -----------------------------------------------------------------------------
frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/.temp/
frontend/.cache/
frontend/*.local
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*
frontend/pnpm-debug.log*

# Auto-generated TypeScript declarations
frontend/auto-imports.d.ts
frontend/components.d.ts

# Frontend runtime directories
frontend/config/
frontend/config-store/
frontend/logs/

# -----------------------------------------------------------------------------
# Database & Data Files
# -----------------------------------------------------------------------------
# H2 Database files
data/
*.db
*.mv.db
*.trace.db
*.lock.db
data/*.mv.db
data/*.trace.db
data/*.lock.db

# R2DBC temp directory
r2dbc:h2:file/

# -----------------------------------------------------------------------------
# Logs & Runtime
# -----------------------------------------------------------------------------
logs/
*.log
app.log
application.log

# -----------------------------------------------------------------------------
# Configuration (Runtime Generated)
# -----------------------------------------------------------------------------
# Runtime config directories (keep templates)
config/
config-dev/
config-store/

# Environment files (keep .env.example)
.env
.env.local
.env.*.local

# Runtime generated properties
.jairouter-data-dir.properties

# -----------------------------------------------------------------------------
# Documentation & Static Content
# -----------------------------------------------------------------------------
# Internal documentation (not for public)
innerdoc/

# Site build output
site/

# Capture/screenshots directory
capture/

# Static admin data (runtime generated)
src/main/resources/static/admin/data/

# -----------------------------------------------------------------------------
# Monitoring & Observability
# -----------------------------------------------------------------------------
monitoring/prometheus/data/
monitoring/grafana/data/
monitoring/alertmanager/data/

# -----------------------------------------------------------------------------
# OS & System Files
# -----------------------------------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.fuse_hidden*
.directory
.Trash-*

# -----------------------------------------------------------------------------
# Miscellaneous
# -----------------------------------------------------------------------------
# Temporary files
*.tmp
*.temp
*.swp
*.swo
*.bak
*.backup
*.orig

# Archive files (usually downloaded dependencies)
*.zip
*.tar.gz
*.rar
*.7z

# Scripts temp directory (legacy, should not exist)
scripts/docs copy/

# Qwen Code working directory (keep QWEN.md and PROJECT_SUMMARY.md)
.qwen/settings.json
.qwen/settings.json.orig
.qwen/output-language.md

# Test coverage reports (generated by CI)
coverage/
.nyc_output/

# Dependency directories (if using jdeps)
jdeps/

# -----------------------------------------------------------------------------
# Keep Important Files (Exceptions)
# -----------------------------------------------------------------------------
# Keep configuration templates
!config/*.example
!config/*.template
!config/*.yml.example

# Keep documentation assets
!docs/
!logo/

# Keep scripts (organized by function)
!scripts/build/
!scripts/dev/
!scripts/docs/
!scripts/migration/
!scripts/monitoring/
!scripts/test/
!scripts/tools/