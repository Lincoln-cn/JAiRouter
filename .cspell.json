    "yarn.lock",
    "data/**",
    ".qwen/**",
    "frontend/node_modules/**",
    "frontend/dist/**"
  ],
  "overrides": [
    {
      "filename": "**/*.md",
      "ignoreRegExpList": [
        "/```[\\s\\S]*?```/g",
        "/`[^`]*`/g",
        "/\\[.*?\\]\\(.*?\\)/g",
        "/https?:\\/\\/[^\\s)]+/g"
      ]
    },
    {
      "filename": "**/*.yml",
      "ignoreRegExpList": [
        "/\\$\\{[^}]*\\}/g"
      ]
    },
    {
      "filename": "**/*.yaml",
      "ignoreRegExpList": [
        "/\\$\\{[^}]*\\}/g"
      ]
    }
  ]
