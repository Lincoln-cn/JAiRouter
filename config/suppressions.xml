<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suppressions PUBLIC
    "-//Checkstyle//DTD Suppressions Configuration 1.2//EN"
    "https://checkstyle.org/dtds/suppressions_1_2.dtd">

<suppressions>
    <!-- ConstantName: logger/log 是SLF4J/Lombok标准命名约定 -->
    <suppress files=".*\.java" checks="ConstantName"/>

    <!-- HiddenField: Builder模式DTO类、Model类允许参数同名 -->
    <suppress files=".*[A-Z][a-zA-Z]*Metrics\.java" checks="HiddenField"/>
    <suppress files=".*[A-Z][a-zA-Z]*Response\.java" checks="HiddenField"/>
    <suppress files=".*[A-Z][a-zA-Z]*Request\.java" checks="HiddenField"/>
    <suppress files=".*[A-Z][a-zA-Z]*Stats\.java" checks="HiddenField"/>
    <suppress files=".*[A-Z][a-zA-Z]*Metadata\.java" checks="HiddenField"/>
    <suppress files=".*ExporterHealthChecker\.java" checks="HiddenField"/>
    <suppress files=".*StorageHealthServiceImpl\.java" checks="HiddenField"/>
    <suppress files=".*CacheFallbackStrategy\.java" checks="HiddenField"/>
    <suppress files=".*AccountManager\.java" checks="HiddenField"/>
    <suppress files=".*TracingMemoryManager\.java" checks="HiddenField"/>
    <suppress files=".*SlowQueryAlertService\.java" checks="HiddenField"/>
    <suppress files=".*SecurityAuditEventEntity\.java" checks="HiddenField"/>
    <suppress files=".*SecurityAlertService\.java" checks="HiddenField"/>
    <suppress files=".*ConfigurationService\.java" checks="HiddenField"/>
    <suppress files=".*JwtTokenInfo\.java" checks="HiddenField"/>
    <suppress files=".*AsyncTracingProcessor\.java" checks="HiddenField"/>
    
    <!-- DesignForExtension: API类、DTO类、配置类、服务类允许继承扩展 -->
    <suppress files=".*[A-Z][a-zA-Z]*Metrics\.java" checks="DesignForExtension"/>
    <suppress files=".*[A-Z][a-zA-Z]*Response\.java" checks="DesignForExtension"/>
    <suppress files=".*[A-Z][a-zA-Z]*Request\.java" checks="DesignForExtension"/>
    <suppress files=".*[A-Z][a-zA-Z]*Stats\.java" checks="DesignForExtension"/>
    <suppress files=".*[A-Z][a-zA-Z]*Api\.java" checks="DesignForExtension"/>
    <suppress files=".*[A-Z][a-zA-Z]*DTO\.java" checks="DesignForExtension"/>
    <suppress files=".*Builder\.java" checks="DesignForExtension"/>
    <suppress files=".*Properties\.java" checks="DesignForExtension"/>
    <suppress files=".*Config\.java" checks="DesignForExtension"/>
    <suppress files=".*Validator\.java" checks="DesignForExtension"/>
    <suppress files=".*Service\.java" checks="DesignForExtension"/>
    <suppress files=".*Controller\.java" checks="DesignForExtension"/>
    <suppress files=".*Manager\.java" checks="DesignForExtension"/>
    <suppress files=".*Repository\.java" checks="DesignForExtension"/>
    <suppress files=".*Provider\.java" checks="DesignForExtension"/>
    <suppress files=".*Filter\.java" checks="DesignForExtension"/>
    <suppress files=".*Handler\.java" checks="DesignForExtension"/>
    <suppress files=".*Registry\.java" checks="DesignForExtension"/>
    <suppress files=".*Factory\.java" checks="DesignForExtension"/>
    <suppress files=".*Strategy\.java" checks="DesignForExtension"/>
    <suppress files=".*Policy\.java" checks="DesignForExtension"/>
    <suppress files=".*Adapter\.java" checks="DesignForExtension"/>
    <suppress files=".*LoadBalancer\.java" checks="DesignForExtension"/>
    <suppress files=".*RateLimiter\.java" checks="DesignForExtension"/>
    <suppress files=".*CircuitBreaker\.java" checks="DesignForExtension"/>
    <suppress files=".*Cache\.java" checks="DesignForExtension"/>
    <suppress files=".*Event\.java" checks="DesignForExtension"/>
    <suppress files=".*Entity\.java" checks="DesignForExtension"/>
    <suppress files=".*Exception\.java" checks="DesignForExtension"/>
    <suppress files=".*Constants\.java" checks="DesignForExtension"/>
    <suppress files=".*Wrapper\.java" checks="DesignForExtension"/>
    <suppress files=".*Snapshot\.java" checks="DesignForExtension"/>
    <suppress files=".*Info\.java" checks="DesignForExtension"/>
    <suppress files=".*Context\.java" checks="DesignForExtension"/>
    <suppress files=".*Result\.java" checks="DesignForExtension"/>
    <suppress files=".*Record\.java" checks="DesignForExtension"/>
    <suppress files=".*HealthChecker\.java" checks="DesignForExtension"/>
    
    <!-- FinalClass: 内部类设计为final -->
    <suppress files=".*\.java" checks="FinalClass"/>

    <!-- HideUtilityClassConstructor: 工具类私有构造器 -->
    <suppress files=".*\.java" checks="HideUtilityClassConstructor"/>

    <!-- NeedBraces: 单行语句允许无括号 -->
    <suppress files=".*\.java" checks="NeedBraces"/>

    <!-- MissingSwitchDefault: switch允许无default -->
    <suppress files=".*\.java" checks="MissingSwitchDefault"/>

    <!-- WhitespaceAround: 特定情况允许 -->
    <suppress files=".*\.java" checks="WhitespaceAround"/>

    <!-- LeftCurly: 特定格式允许 -->
    <suppress files=".*\.java" checks="LeftCurly"/>

    <!-- LocalFinalVariableName: 局部变量命名 -->
    <suppress files=".*\.java" checks="LocalFinalVariableName"/>

    <!-- LocalVariableName: 局部变量命名 -->
    <suppress files=".*\.java" checks="LocalVariableName"/>

    <!-- MemberName: 成员命名 -->
    <suppress files=".*\.java" checks="MemberName"/>

    <!-- MethodName: 方法命名 -->
    <suppress files=".*\.java" checks="MethodName"/>

    <!-- RightCurly: 右大括号位置 -->
    <suppress files=".*\.java" checks="RightCurly"/>

    <!-- FileLength: 文件长度 -->
    <suppress files=".*\.java" checks="FileLength"/>

    <!-- LineLength: 配置类、DTO类允许较长行（常量定义、链式调用） -->
    <suppress files=".*Properties\.java" checks="LineLength"/>
    <suppress files=".*Application\.java" checks="LineLength"/>
    <suppress files=".*[A-Z][a-zA-Z]*DTO\.java" checks="LineLength"/>
    <suppress files=".*[A-Z][a-zA-Z]*Response\.java" checks="LineLength"/>
    <suppress files=".*[A-Z][a-zA-Z]*Request\.java" checks="LineLength"/>

    <!-- FinalParameters: Spring推荐不加final -->
    <suppress files=".*\.java" checks="FinalParameters"/>

    <!-- VisibilityModifier: DTO类、Entity类、内部类需要public字段 -->
    <suppress files=".*\.java" checks="VisibilityModifier"/>
</suppressions>